{
    "name": "saifulferoz/symfony-horizon",
    "description": "Laravel Horizon style dashboard and queue worker monitoring for Symfony Messenger",
    "type": "symfony-bundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Saiful Islam Feroz",
            "email": "saifulferoz@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "symfony/framework-bundle": "^6.4 || ^7.0 || ^8.0",
        "symfony/messenger": "^6.4 || ^7.0 || ^8.0",
        "symfony/process": "^6.4 || ^7.0 || ^8.0",
        "symfony/cache": "^6.4 || ^7.0 || ^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0"
    },
    "autoload": {
        "psr-4": {
            "Saifulferoz\\SymfonyHorizon\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Saifulferoz\\SymfonyHorizon\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
